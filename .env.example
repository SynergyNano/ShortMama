# ========== MongoDB ==========
MONGODB_URI=
MONGODB_DB_NAME=shortmama
# 선택: 연결 풀 (기본 max 25, min 2)
# MONGODB_MAX_POOL_SIZE=25
# MONGODB_MIN_POOL_SIZE=2

# ========== NextAuth (Auth.js v5) ==========
AUTH_SECRET=
AUTH_URL=
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ========== 이메일 (Resend) ==========
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=no-reply@your-domain.com

# ========== 결제 (토스) ==========
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_CLIENT_SECRET=test_sk_xxxx
# 선택: 웹훅 서명 강제 (기본 false)
# TOSS_WEBHOOK_REQUIRE_SIGNATURE=true

# ========== 크론 / 배치 ==========
CRON_SECRET=랜덤_긴_문자열_여기에_입력

# ========== Redis + BullMQ (검색 큐) ==========
# 코드 변수명: REDIS_URL (다른 이름 사용 시 연결 안 됨)
REDIS_URL=redis://localhost:6379
# 로컬·배포 같은 큐 쓰려면 동일 값으로 맞춤 (기본: dev=video-search-dev, prod=video-search)
# QUEUE_NAME=video-search

# ========== Apify (스크래핑) ==========
# 코드 변수명: APIFY_API_KEY (APIFY_KEY 아님)
APIFY_API_KEY=apify_api_xxxx

# ========== 워커 (Railway worker 등) ==========
# WORKER_CONCURRENCY=50

# ========== 링크 자동 갱신 (recrawl) ==========
# RECRAWL_ENABLE_AUTO=true
# RECRAWL_RATE_LIMIT_PER_HOUR=3

# ========== 할당량 ==========
# 일일 한도 — apiUsage·userLimits 공통 (API_DAILY_LIMIT 권장)
API_DAILY_LIMIT=20
# 레거시: DEFAULT_DAILY_LIMIT (API_DAILY_LIMIT 없을 때만 의미 있음)
# DEFAULT_DAILY_LIMIT=20
FREE_SIGNUP_LIMIT=50

# ========== 기타 API ==========
# 자막 추출 등 (선택)
# OPENAI_API_KEY=
